{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug extension with automation support",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/controller-extension",
        "--remote-debugging-port=9222",
        "--user-data-dir=${workspaceFolder}/.vscode-test-user-data",
        "--disable-workspace-trust"
      ],
      "env": {
        "VSCODE_EXT_TESTER_PORT": "9788"
      }
    }
  ]
}
